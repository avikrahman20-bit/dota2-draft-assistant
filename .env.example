# Dota 2 Draft Assistant — environment configuration
# Copy this file to .env and fill in your keys.

# Stratz API key — get one free at https://stratz.com/api
STRATZ_API_KEY=your_stratz_api_key_here

# Anthropic API key — required for AI chat assistant
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT signing secret — auto-generated on first run.
# DO NOT set this manually unless you are migrating an existing users.db
# to a new machine and need sessions to remain valid.
# JWT_SECRET=
